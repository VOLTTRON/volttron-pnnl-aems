COMPOSE_PROJECT_NAME=skeleton
COMPOSE_CONVERT_WINDOWS_PATHS=true
COMPOSE_CONTAINER_REGISTRY=localhost

# App version for docker compose image tagging.
TAG=latest

# Application

# All test ports in this file should be set to an empty string when not needed for development or testing.
# Application test ports for http test access or when not using the proxy.
CLIENT_TEST_PORT=
SERVER_TEST_PORT=
# Uncomment to expose the application for testing.
# CLIENT_TEST_PORT=8443
# SERVER_TEST_PORT=9443
# ICE_CREAM_TEST_PORT=7443
# Available loggers are: console and database
LOGGERS=console,database
# Available authentication providers are: local, super, bearer, keycloak
AUTH_PROVIDERS=keycloak
SESSION_SECRET=SeT_tHiS_iN_0x3A-.env.secrets-
# Application bearer configuration
JWT_SECRET=SeT_tHiS_iN_0x3A-.env.secrets-
WORKER_TOKEN=SeT_tHiS_iN_0x3A-.env.secrets-
# Application local configuration
# Password minimum strength from 0 to 4.
PASSWORD_STRENGTH=2
PASSWORD_VALIDATE=true
# Application keycloak configuration 
# This client secret was generated for the pre-configured Keycloak default app client.
# It should be changed for production use.
KEYCLOAK_CLIENT_SECRET=SeT_tHiS_iN_0x3A-.env.secrets-
KEYCLOAK_PASS_ROLES=false
KEYCLOAK_DEFAULT_ROLE=user
# Application Proxy Configuration
# These are used by the application services.
PROXY_PROTOCOL=
PROXY_HOST=
PROXY_PORT=
# These are used by images and containers during build and setup scripts.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
NODE_TLS_REJECT_UNAUTHORIZED=1
# Necessary when building images behind a proxy.
# HTTP_PROXY=http://proxy01.pnl.gov:3128
# HTTPS_PROXY=http://proxy01.pnl.gov:3128
# NO_PROXY=*.pnl.gov,*.pnnl.gov,127.0.0.1
# NODE_TLS_REJECT_UNAUTHORIZED=0

# Database
DATABASE_NAME=skeleton
DATABASE_USERNAME=skeleton
DATABASE_PASSWORD=SeT_tHiS_iN_0x3A-.env.secrets-

# Redis
REDIS_USERNAME=
REDIS_PASSWORD=SeT_tHiS_iN_0x3A-.env.secrets-

# Profile

# Available profiles are: 
# map    (Open Street Map)
# nom    (Nominatim)
# proxy  (Traefik)
# sso    (Keycloak)
# wiki   (Bookstack)
# redis  (Redis)
COMPOSE_PROFILES=map,nom,proxy,sso,wiki,redis

# Open Street Map Tiles

# Configuration for Open Street Map Tiles is located at: ./map/config.json

# Nominatim

# URLs for map data can be found here: https://download.geofabrik.de/
# PBF_PATH or PBF_URL is required
# Uncomment the following lines to use local data.
# PBF_PATH=/nominatim/data/planet.osm.pbf
# PBF_URL=
# REPLICATION_URL=
# POLY_URL=
# Uncomment the following lines to use online data.
PBF_PATH=
PBF_URL=https://download.geofabrik.de/north-america/us/washington-latest.osm.pbf
REPLICATION_URL=https://download.geofabrik.de/north-america/us/washington-updates/
POLY_URL=https://download.geofabrik.de/north-america/us/washington.poly
NOMINATIM_DATABASE_PASSWORD=SeT_tHiS_iN_0x3A-.env.secrets-

# Traefik

# Hostname or IP Address for the Traefik Proxy and main application.
# The volume 'certs-data' will need to be deleted if the hostname is changed.
# New certs will be recreated when the certs container is restarted.
# A valid admin email is required when requesting certificates from Let's Encrypt.
ADMIN_EMAIL=your.email@example.com
# Uncomment CERT_RESOLVER=letsencrypt to use Let's Encrypt.
CERT_RESOLVER=
# CERT_RESOLVER=letsencrypt
# Use your IP address as the hostname for development and testing of Keycloak.
# NOTE: Named APP_HOSTNAME (not HOSTNAME) because bash exports HOSTNAME as a
# built-in short machine name, which would override a value set here when
# compose interpolates ${APP_HOSTNAME} at up-time.
APP_HOSTNAME=test.local
# Optional: set to your machine's LAN IP to include it as a SAN in the local cert.
# The volume 'certs-data' will need to be deleted and certs container restarted
# after changing this value.
HOST_IP=

# Bookstack

# Bookstack is provided as an example external application secured service that uses single sign on.
BOOKSTACK_SESSION_SECRET=SeT_tHiS_iN_0x3A-.env.secrets-
BOOKSTACK_ROOT_PASSWORD=SeT_tHiS_iN_0x3A-.env.secrets-
BOOKSTACK_DATABASE_NAME=bookstack
BOOKSTACK_DATABASE_USERNAME=bookstack
BOOKSTACK_DATABASE_PASSWORD=SeT_tHiS_iN_0x3A-.env.secrets-
BOOKSTACK_KEYCLOAK_CLIENT_ID=wiki
BOOKSTACK_KEYCLOAK_CLIENT_SECRET=SeT_tHiS_iN_0x3A-.env.secrets-

# Keycloak

# Keycloak is configured to utilize the Traefik proxy by default.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=SeT_tHiS_iN_0x3A-.env.secrets-
KEYCLOAK_DATABASE_NAME=keycloak
KEYCLOAK_DATABASE_USERNAME=keycloak
KEYCLOAK_DATABASE_PASSWORD=SeT_tHiS_iN_0x3A-.env.secrets-
