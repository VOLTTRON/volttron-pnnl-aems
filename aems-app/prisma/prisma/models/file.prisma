model File {
    id            String    @id() @default(cuid())
    mimeType      String
    contentLength Int
    objectKey     String
    createdAt     DateTime  @default(now()) @db.Timestamptz(6)
    updatedAt     DateTime  @updatedAt() @db.Timestamptz(6)
    userId        String?
    feedbackId    String?
    user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
    feedback      Feedback? @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

    @@index([mimeType], map: "files_mimeType")
    @@index([createdAt], map: "files_createdAt")
    @@index([updatedAt], map: "files_updatedAt")
    @@index([userId], map: "files_userId")
    @@index([feedbackId], map: "files_feedbackId")
}
