model VerificationToken {
    id         String   @default(cuid())
    identifier String
    token      String   @unique()
    expiresAt  DateTime
    createdAt  DateTime @default(now()) @db.Timestamptz(6)
    updatedAt  DateTime @updatedAt() @db.Timestamptz(6)
    userId     String
    user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@id([identifier, token])
    @@unique([id])
    @@index([expiresAt], map: "verification_tokens_expiresAt")
    @@index([createdAt], map: "verification_tokens_createdAt")
    @@index([updatedAt], map: "verification_tokens_updatedAt")
    @@index([userId], map: "verification_tokens_userId")
}
