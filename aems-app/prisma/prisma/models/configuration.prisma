model Configuration {
    // key
    id                  String      @id() @default(cuid())
    // metadata
    stage               ModelStage  @default(Create)
    message             String?     @db.VarChar(1024)
    correlation         String?     @db.VarChar(1024)
    createdAt           DateTime    @default(now()) @db.Timestamptz(6)
    updatedAt           DateTime    @updatedAt @db.Timestamptz(6)
    // fields
    label               String      @db.VarChar(1024)
    // foreign keys
    setpointId          String?
    mondayScheduleId    String?
    tuesdayScheduleId   String?
    wednesdayScheduleId String?
    thursdayScheduleId  String?
    fridayScheduleId    String?
    saturdayScheduleId  String?
    sundayScheduleId    String?
    holidayScheduleId   String?
    // direct relations
    setpoint            Setpoint?   @relation("Configurations_setpoints", fields: [setpointId], references: [id], onDelete: Cascade)
    mondaySchedule      Schedule?   @relation("Configurations_mondaySchedules", fields: [mondayScheduleId], references: [id], onDelete: Cascade)
    tuesdaySchedule     Schedule?   @relation("Configurations_tuesdaySchedules", fields: [tuesdayScheduleId], references: [id], onDelete: Cascade)
    wednesdaySchedule   Schedule?   @relation("Configurations_wednesdaySchedules", fields: [wednesdayScheduleId], references: [id], onDelete: Cascade)
    thursdaySchedule    Schedule?   @relation("Configurations_thursdaySchedules", fields: [thursdayScheduleId], references: [id], onDelete: Cascade)
    fridaySchedule      Schedule?   @relation("Configurations_fridaySchedules", fields: [fridayScheduleId], references: [id], onDelete: Cascade)
    saturdaySchedule    Schedule?   @relation("Configurations_saturdaySchedules", fields: [saturdayScheduleId], references: [id], onDelete: Cascade)
    sundaySchedule      Schedule?   @relation("Configurations_sundaySchedules", fields: [sundayScheduleId], references: [id], onDelete: Cascade)
    holidaySchedule     Schedule?   @relation("Configurations_holidaySchedules", fields: [holidayScheduleId], references: [id], onDelete: Cascade)
    // indirect relations
    units               Unit[]      @relation("Units_configurations")
    occupancies         Occupancy[] @relation("Occupancies_configurations")
    holidays            Holiday[]   @relation()

    // indices
    @@index([label])
    @@index([stage])
    @@index([createdAt], map: "configurations_createdAt")
    @@index([updatedAt], map: "configurations_updatedAt")
    @@index([setpointId], map: "configurations_setpointId")
    @@index([mondayScheduleId], map: "configurations_mondayScheduleId")
    @@index([tuesdayScheduleId], map: "configurations_tuesdayScheduleId")
    @@index([wednesdayScheduleId], map: "configurations_wednesdayScheduleId")
    @@index([thursdayScheduleId], map: "configurations_thursdayScheduleId")
    @@index([fridayScheduleId], map: "configurations_fridayScheduleId")
    @@index([saturdayScheduleId], map: "configurations_saturdayScheduleId")
    @@index([sundayScheduleId], map: "configurations_sundayScheduleId")
    @@index([holidayScheduleId], map: "configurations_holidayScheduleId")
}
