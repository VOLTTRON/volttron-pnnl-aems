model Schedule {
    // key
    id                      String          @id() @default(cuid())
    // metadata
    stage                   ModelStage      @default(Create)
    message                 String?         @db.VarChar(1024)
    correlation             String?         @db.VarChar(1024)
    createdAt               DateTime        @default(now()) @db.Timestamptz(6)
    updatedAt               DateTime        @updatedAt @db.Timestamptz(6)
    // fields
    label                   String          @db.VarChar(1024)
    startTime               String          @default("08:00")
    endTime                 String          @default("18:00")
    occupied                Boolean         @default(true)
    override                Boolean         @default(false)
    overridePreStartTime    String          @default("00:00")
    overridePreEndTime      String          @default("00:00")
    overridePostStartTime   String          @default("24:00")
    overridePostEndTime     String          @default("24:00")
    // foreign keys
    setpointId              String?
    // direct relations
    setpoint                Setpoint?       @relation("Schedules_setpoints", fields: [setpointId], references: [id], onDelete: Cascade)
    // indirect relations
    mondayConfigurations    Configuration[] @relation("Configurations_mondaySchedules")
    tuesdayConfigurations   Configuration[] @relation("Configurations_tuesdaySchedules")
    wednesdayConfigurations Configuration[] @relation("Configurations_wednesdaySchedules")
    thursdayConfigurations  Configuration[] @relation("Configurations_thursdaySchedules")
    fridayConfigurations    Configuration[] @relation("Configurations_fridaySchedules")
    saturdayConfigurations  Configuration[] @relation("Configurations_saturdaySchedules")
    sundayConfigurations    Configuration[] @relation("Configurations_sundaySchedules")
    holidayConfigurations   Configuration[] @relation("Configurations_holidaySchedules")
    occupancies             Occupancy[]     @relation("Occupancies_schedules")

    // indices
    @@index([label])
    @@index([stage])
    @@index([createdAt], map: "schedules_createdAt")
    @@index([updatedAt], map: "schedules_updatedAt")
    @@index([setpointId], map: "schedules_setpointId")
}
