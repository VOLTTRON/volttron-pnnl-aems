# Client configuration options that are needed in the browser must be prefixed with `NEXT_PUBLIC_`.
# These are the only variables that will be available to client-side code.
PROJECT_NAME=aems
HOSTNAME=localhost
# Node runtime flags.
# --preserve-symlinks is required so that sibling packages linked via Yarn
# `portal:` protocol (e.g. @local/common, @local/prisma) resolve their own
# dependencies through the symlinked directory rather than the consumer's
# node_modules. See Yarn warning YN0072.
NODE_OPTIONS=--preserve-symlinks
# Next.js build output of types: standalone, export, or 'undefined'
BUILD_OUTPUT=
# public client variables
NEXT_PUBLIC_TITLE=AEMS
NEXT_PUBLIC_DESCRIPTION=
NEXT_PUBLIC_KEYWORDS=
NEXT_PUBLIC_ADMIN_EMAIL=
NEXT_PUBLIC_HIDDEN_ROUTES=
NEXT_PUBLIC_HIDDEN_LOGINS=bearer,super
NEXT_PUBLIC_MAP_DARK_STYLE=/ext/map/styles/fiord-color/style.json
NEXT_PUBLIC_MAP_LIGHT_STYLE=/ext/map/styles/positron/style.json
NEXT_PUBLIC_GRAPHQL_API=/graphql
NEXT_PUBLIC_GRAPHQL_WS=/graphql
NEXT_PUBLIC_HTTP_API=/api
NEXT_PUBLIC_EXT_PATH=/ext
NEXT_PUBLIC_AUTHJS_LOGIN_URL=/authjs/signin
NEXT_PUBLIC_AUTHJS_LOGOUT_URL=/authjs/signout
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org/search?format=json&limit=10&addressdetails=1
NEXT_PUBLIC_GRAFANA_LINKS=false
# NEXT_PUBLIC_NOMINATIM_URL=${NEXT_PUBLIC_EXT_PATH}/nominatim/search?format=jsonv2&limit=10
NEXT_PUBLIC_INFO_CRON_URL=https://crontab.io/
# Keycloak SSO — mirrors server KEYCLOAK_ISSUER_URL (e.g. https://hostname/auth/sso/realms/default)
# Used to derive the admin console URL for the Keycloak management page.
NEXT_PUBLIC_KEYCLOAK_ISSUER_URL=
# redis
REDIS_HOST=localhost
REDIS_PORT=6379
# database
DATABASE_URL="postgresql://${DATABASE_USERNAME}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=${DATABASE_SCHEMA}&connection_limit=5"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=aems-develop
DATABASE_SCHEMA=public
DATABASE_USERNAME=develop
DATABASE_PASSWORD=password
# development
REWRITE_AUTHJS_URL=https://localhost/authjs
REWRITE_GRAPHQL_URL=https://localhost/graphql
REWRITE_API_URL=https://localhost/api
REWRITE_EXT_URL=https://localhost/ext
# volttron
VOLTTRON_CAMPUS=PNNL
VOLTTRON_BUILDING=ROB
