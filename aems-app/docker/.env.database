# Environment variables for the database container
PGUSER=${DATABASE_USERNAME}
POSTGRES_USER=${DATABASE_USERNAME}
POSTGRES_DB=${DATABASE_NAME}
# `POSTGRES_PASSWORD` is set on the service's `environment:` block in
# docker-compose.yml via `${POSTGRES_PASSWORD-${DATABASE_PASSWORD}}` so
# that `secrets.sh`-driven runs can blank it (via `.env.secrets.docker`)
# without disturbing `DATABASE_PASSWORD` elsewhere. Do not set
# `POSTGRES_PASSWORD` here.