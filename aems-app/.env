# =============================================================================
# AEMS Master Configuration
# =============================================================================
# This is the root .env file. Per-service .env.* files in docker/ interpolate
# from these values. Edit THIS file, not the per-service files.
#
# Secrets: Replace all "CHANGE_ME_*" placeholders with real values.
# Generate strong passwords with: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=aems
COMPOSE_CONVERT_WINDOWS_PATHS=true
# Set to "localhost" for local builds, or a registry URL for remote images.
COMPOSE_CONTAINER_REGISTRY=localhost
# Image tag. Use "latest" for local builds.
TAG=latest

# -----------------------------------------------------------------------------
# Profiles
# -----------------------------------------------------------------------------
# Available profiles:
#   proxy          - Traefik reverse proxy + TLS
#   sso            - Keycloak single sign-on
#   redis          - Redis cache/sessions
#   fastapi        - FastAPI message bus + historian DB
#   fastapi-agents - Agent containers (listener, historian, manager, weather, nf-driver, ilc)
#   grafana        - Monitoring dashboards
#   sim-rtu        - Simulated RTU devices (dev/testing only)
#   volttron       - Legacy VOLTTRON monolith (DO NOT combine with fastapi)
#   map            - OpenStreetMap tiles
#   nom            - Nominatim geocoding
#   wiki           - Bookstack wiki
#
# Examples:
#   Production:    COMPOSE_PROFILES=proxy,sso,redis,fastapi,fastapi-agents,grafana
#   Dev (sim):     COMPOSE_PROFILES=fastapi,fastapi-agents,sim-rtu
#   Minimal:       COMPOSE_PROFILES=fastapi,fastapi-agents
#   Legacy:        COMPOSE_PROFILES=proxy,sso,redis,volttron,grafana
#
# WARNING: Do not enable both "volttron" and "fastapi" -- port 5410 conflict.
COMPOSE_PROFILES=proxy,sso,redis,fastapi,fastapi-agents,grafana

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Test ports: set to empty string to disable, uncomment to expose for dev.
CLIENT_TEST_PORT=
SERVER_TEST_PORT=
# CLIENT_TEST_PORT=8443
# SERVER_TEST_PORT=9443

# Logging: console, database
LOGGERS=console,database

# Auth providers: local, super, bearer, keycloak
AUTH_PROVIDERS=keycloak

# Session and JWT secrets (MUST change for production)
SESSION_SECRET=CHANGE_ME_session_secret
JWT_SECRET=CHANGE_ME_jwt_secret

# Keycloak client secrets (regenerate in Keycloak admin for production)
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_keycloak_client_secret
KEYCLOAK_GRAFANA_CLIENT_SECRET=CHANGE_ME_keycloak_grafana_client_secret
KEYCLOAK_PASS_ROLES=false
KEYCLOAK_DEFAULT_ROLE=

# Password policy (local auth only)
PASSWORD_STRENGTH=2
PASSWORD_VALIDATE=true

# Proxy settings (uncomment if behind corporate proxy)
PROXY_PROTOCOL=
PROXY_HOST=
PROXY_PORT=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
NODE_TLS_REJECT_UNAUTHORIZED=1
# HTTP_PROXY=http://proxy01.pnl.gov:3128
# HTTPS_PROXY=http://proxy01.pnl.gov:3128
# NO_PROXY=*.pnl.gov,*.pnnl.gov,127.0.0.1
# NODE_TLS_REJECT_UNAUTHORIZED=0

# -----------------------------------------------------------------------------
# Database (application)
# -----------------------------------------------------------------------------
DATABASE_NAME=aems
DATABASE_USERNAME=aems
DATABASE_PASSWORD=CHANGE_ME_database_password
DATABASE_TEST_PORT=
# DATABASE_TEST_PORT=6543

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_USERNAME=redis
REDIS_PASSWORD=CHANGE_ME_redis_password
REDIS_TEST_PORT=
# REDIS_TEST_PORT=6379

# -----------------------------------------------------------------------------
# Traefik Proxy
# -----------------------------------------------------------------------------
# FQDN or IP for the proxy and main application.
# Delete the "certs-data" volume if you change this (new certs will be generated).
HOSTNAME=172.31.32.1
ADMIN_EMAIL=your.email@example.com
# Uncomment for Let's Encrypt production certs:
CERT_RESOLVER=
# CERT_RESOLVER=letsencrypt
TRAEFIK_TEST_PORT=
# TRAEFIK_TEST_PORT=8080

# -----------------------------------------------------------------------------
# Keycloak SSO
# -----------------------------------------------------------------------------
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_keycloak_admin_password
KEYCLOAK_DATABASE_NAME=keycloak
KEYCLOAK_DATABASE_USERNAME=keycloak
KEYCLOAK_DATABASE_PASSWORD=CHANGE_ME_keycloak_db_password
KEYCLOAK_TEST_PORT=
# KEYCLOAK_TEST_PORT=8880

# -----------------------------------------------------------------------------
# Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_grafana_admin_password
GRAFANA_DATABASE_PASSWORD=CHANGE_ME_grafana_db_password
GRAFANA_TEST_PORT=
# GRAFANA_TEST_PORT=3000

# -----------------------------------------------------------------------------
# Historian Database
# -----------------------------------------------------------------------------
HISTORIAN_DATABASE_PASSWORD=CHANGE_ME_historian_db_password
HISTORIAN_REPLICATOR_PASSWORD=CHANGE_ME_historian_replicator_password
HISTORIAN_REPLICATION_PORT=6543
HISTORIAN_DB_PORT=5543
HISTORIAN_TEST_PORT=
# HISTORIAN_TEST_PORT=15432

# -----------------------------------------------------------------------------
# Edge Platform (VOLTTRON / FastAPI agents)
# -----------------------------------------------------------------------------
# These variables drive fastapi-setup config generation.
VOLTTRON_CA=/certs/mkcert-ca.crt
VOLTTRON_MOCKED=false
VOLTTRON_VERBOSE=true
VOLTTRON_AUTH_URL=http://host.docker.internal:5410/authenticate
VOLTTRON_API_URL=http://host.docker.internal:5410/gs
VOLTTRON_USERNAME=admin
VOLTTRON_PASSWORD=admin
VOLTTRON_SETUP_THERMOSTAT_PATHS=/app/volttron/configs/configuration_store/
VOLTTRON_SETUP_ILC_PATHS=/app/volttron/site.json
VOLTTRON_SETUP_TEMPLATE_PATHS=/app/volttron/templates/
VOLTTRON_REGISTRY_FILE_PATH=

# Site identification
VOLTTRON_CAMPUS=PNNL
VOLTTRON_BUILDING=ROB
VOLTTRON_PREFIX=rtu
VOLTTRON_NUM_CONFIGS=5

# Network / gateway
VOLTTRON_GATEWAY_ADDRESS=192.168.1.1
VOLTTRON_BACNET_ADDRESS=
# NF driver gateway URL (for FastAPI profile, runs inside Docker)
VOLTTRON_NF_GATEWAY_URL=http://host.docker.internal:8081

# Timezone and weather
VOLTTRON_TIMEZONE=America/Los_Angeles
VOLTTRON_WEATHER_STATION=KPSC

# ILC (Intelligent Load Control)
VOLTTRON_ILC=true

# Email notifications (optional)
VOLTTRON_SMTP_ADDRESS=smtp.gmail.com
VOLTTRON_SMTP_USERNAME=
VOLTTRON_SMTP_PASSWORD=
VOLTTRON_SMTP_PORT=587
VOLTTRON_SMTP_TLS=true
VOLTTRON_EMAIL_FROM_ADDRESS=no-reply@aems.pnl.gov
VOLTTRON_EMAIL_TO_ADDRESSES=
VOLTTRON_EMAIL_ALLOW_FREQUENCY_MINUTES=1440

# Meter (optional)
VOLTTRON_METER_PREFIX=
VOLTTRON_METER_IP=
VOLTTRON_RTU_OAT_SENSOR_NUMBER=

# -----------------------------------------------------------------------------
# Simulated RTU (sim-rtu profile only)
# -----------------------------------------------------------------------------
# Set to empty to use defaults (8080/47808). Set explicit ports to avoid conflicts.
SIM_RTU_API_PORT=
SIM_RTU_BACNET_PORT=

# -----------------------------------------------------------------------------
# OpenStreetMap Tiles (map profile only)
# -----------------------------------------------------------------------------
MAPTILES_TEST_PORT=
# MAPTILES_TEST_PORT=4080

# -----------------------------------------------------------------------------
# Nominatim Geocoding (nom profile only)
# -----------------------------------------------------------------------------
# URLs: https://download.geofabrik.de/
PBF_PATH=
PBF_URL=
REPLICATION_URL=
POLY_URL=
NOMINATIM_DATABASE_PASSWORD=CHANGE_ME_nominatim_db_password
NOMINATIM_TEST_PORT=
# NOMINATIM_TEST_PORT=5080

# -----------------------------------------------------------------------------
# Bookstack Wiki (wiki profile only)
# -----------------------------------------------------------------------------
BOOKSTACK_SESSION_SECRET=CHANGE_ME_bookstack_session_secret
BOOKSTACK_ROOT_PASSWORD=CHANGE_ME_bookstack_root_password
BOOKSTACK_DATABASE_NAME=bookstack
BOOKSTACK_DATABASE_USERNAME=bookstack
BOOKSTACK_DATABASE_PASSWORD=CHANGE_ME_bookstack_db_password
BOOKSTACK_KEYCLOAK_CLIENT_ID=wiki
BOOKSTACK_KEYCLOAK_CLIENT_SECRET=CHANGE_ME_bookstack_keycloak_secret
BOOKSTACK_TEST_PORT=
BOOKSTACK_DATABASE_TEST_PORT=
# BOOKSTACK_TEST_PORT=6080
# BOOKSTACK_DATABASE_TEST_PORT=3306
