# =============================================================================
# AEMS Master Configuration
# =============================================================================
# This is the root .env file. Per-service .env.* files in docker/ interpolate
# from these values. Edit THIS file, not the per-service files.
#
# Secrets: Replace all "CHANGE_ME_*" placeholders with real values.
# Generate strong passwords with: openssl rand -base64 32
# =============================================================================

# -----------------------------------------------------------------------------
# Docker Compose
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=aems
COMPOSE_CONVERT_WINDOWS_PATHS=true
# Set to "localhost" for local builds, or a registry URL for remote images.
COMPOSE_CONTAINER_REGISTRY=localhost
# Image tag. Use "latest" for local builds.
TAG=latest

# -----------------------------------------------------------------------------
# Profiles
# -----------------------------------------------------------------------------
# Available profiles:
#   proxy          - Traefik reverse proxy + TLS
#   sso            - Keycloak single sign-on
#   redis          - Redis cache/sessions
#   fastapi        - FastAPI message bus + historian DB
#   fastapi-agents - Agent containers (listener, historian, manager, weather, nf-driver, ilc)
#   grafana        - Monitoring dashboards
#   sim-rtu        - Simulated RTU devices (dev/testing only)
#   volttron       - Legacy VOLTTRON monolith (DO NOT combine with fastapi)
#   map            - OpenStreetMap tiles
#   nom            - Nominatim geocoding
#   wiki           - Bookstack wiki
#
# Examples:
#   Production:    COMPOSE_PROFILES=proxy,sso,redis,fastapi,fastapi-agents,grafana
#   Dev (sim):     COMPOSE_PROFILES=fastapi,fastapi-agents,sim-rtu
#   Minimal:       COMPOSE_PROFILES=fastapi,fastapi-agents
#   Legacy:        COMPOSE_PROFILES=proxy,sso,redis,volttron,grafana
#
# WARNING: Do not enable both "volttron" and "fastapi" -- port 5410 conflict.
COMPOSE_PROFILES=proxy,sso,redis,fastapi,fastapi-agents,grafana

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
# Test ports: set to empty string to disable, uncomment to expose for dev.
CLIENT_TEST_PORT=
SERVER_TEST_PORT=
# CLIENT_TEST_PORT=8443
# SERVER_TEST_PORT=9443

# Logging: console, database
LOGGERS=console,database

# Auth providers: local, super, bearer, keycloak
AUTH_PROVIDERS=keycloak

# Session and JWT secrets (MUST change for production)
SESSION_SECRET=CHANGE_ME_session_secret
JWT_SECRET=CHANGE_ME_jwt_secret

# Keycloak client secrets (regenerate in Keycloak admin for production)
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_keycloak_client_secret
KEYCLOAK_GRAFANA_CLIENT_SECRET=CHANGE_ME_keycloak_grafana_client_secret
KEYCLOAK_PASS_ROLES=false
KEYCLOAK_DEFAULT_ROLE=

# Password policy (local auth only)
PASSWORD_STRENGTH=2
PASSWORD_VALIDATE=true

# Proxy settings (uncomment if behind corporate proxy)
PROXY_PROTOCOL=
PROXY_HOST=
PROXY_PORT=
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=
NODE_TLS_REJECT_UNAUTHORIZED=1
# HTTP_PROXY=http://proxy01.pnl.gov:3128
# HTTPS_PROXY=http://proxy01.pnl.gov:3128
# NO_PROXY=*.pnl.gov,*.pnnl.gov,127.0.0.1
# NODE_TLS_REJECT_UNAUTHORIZED=0

# -----------------------------------------------------------------------------
# Database (application)
# -----------------------------------------------------------------------------
DATABASE_NAME=aems
DATABASE_USERNAME=aems
