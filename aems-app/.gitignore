# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# temp
.docker_temp_*
docker-images.**

# tmp/files
./tmp/

# editor config
.idea
# .vscode
.DS_Store
# claude
.claude/settings.local.json

# secrets
.env.secrets
docker/secrets/
# but keep the empty placeholder and the empty secrets env file tracked —
# .placeholder is bind-mounted for every declared secret when secrets.sh
# hasn't been run; .env.secrets.docker is referenced by the root include:
# env_file so compose picks up _SOURCE vars without any --env-file flags.
# secrets.sh populates both; they start empty so the placeholder fallbacks win.
!docker/secrets/.placeholder
!docker/.env.secrets.docker

# backups
docker/backups/

# other
*.bat
*.log
