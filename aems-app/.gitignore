# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# temp
.docker_temp_*
docker-images.**

# tmp/files
./tmp/

# editor config
.idea
# .vscode
.DS_Store
# claude
.claude/settings.local.json

# secrets
.env.secrets
docker/secrets/
# but keep the empty placeholder tracked — it's what compose bind-mounts
# for every declared secret when the user hasn't run `secrets.sh`, so
# real secret files don't need to exist for `docker compose up` to work.
!docker/secrets/.placeholder
docker/.env.secrets.docker

# backups
docker/backups/

# other
*.bat
*.log
